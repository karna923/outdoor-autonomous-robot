{
  "ros.distro": "jazzy",
  "cmake.configureOnOpen": false,
  "C_Cpp.default.includePath": [
    "/opt/ros/jazzy/include/**",
    "${workspaceFolder}/ros2_ws/src/**",
    "${workspaceFolder}/firmware/**"
  ],
  "C_Cpp.default.compilerPath": "/usr/bin/gcc",
  "C_Cpp.default.cppStandard": "c++17",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.associations": {
    "*.launch.py": "python",
    "*.yaml": "yaml",
    "*.urdf": "xml",
    "*.sdf": "xml"
  },
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "idf.espIdfPath": "/home/pushkar/esp/esp-idf",
  "idf.pythonBinPath": "/home/pushkar/.espressif/python_env/idf5.1_py3.12_env/bin/python",
  "idf.toolsPath": "/home/pushkar/.espressif",
  "idf.port": "/dev/ttyUSB0",
  "terminal.integrated.env.linux": {
    "IDF_PATH": "/home/pushkar/esp/esp-idf",
    "ROS_DISTRO": "jazzy"
  }
}
